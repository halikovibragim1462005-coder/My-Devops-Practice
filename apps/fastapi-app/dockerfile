
#Добавляем образ питона
FROM python

#Создаем рабочую папку
WORKDIR /app
#Устанавливаем зависимости
COPY requirements.txt .
#Кладем наши зависимости внутрь контейнера
RUN pip install --no-cache-dir -r requirements.txt
#Копируем наше приложение в созданную рабочую директорию
COPY main.py .
#Запуск веб сервера для всех хостов на порту 8000
CMD [ "uvicorn", "main:data", "--host", "0.0.0.0", "--port", "8000" ]

#При частых изменений python приложения рекомендуется монтировать его 